FROM python:3.11-slim
 
WORKDIR /app
 
# Install dependencies first (better layer caching)
COPY ai-module/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
 
# Copy the trained model (lives at project root, shared by the team)
COPY models/ /app/models/
 
# Copy the ai-module app code
COPY ai-module/ /app/
 
# Model path is env-overridable, defaults to the baked-in copy
ENV MODEL_PATH=/app/models/isolation_forest_model.pkl
 
EXPOSE 8000
CMD ["uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8000"]
 